<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    
    <persistence-unit name="covoitPU" transaction-type="JTA">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <!-- Liste des entités -->
        <class>com.covoit.model.Utilisateur</class>
        <class>com.covoit.model.PointRendezVous</class>
        <class>com.covoit.model.Signalement</class>
        <class>com.covoit.model.Trajet</class>
        <class>com.covoit.model.Notation</class>
        
        <properties>
            <!-- Ces propriétés dépendront de votre serveur d'application (Wildfly, GlassFish, Payara, TomEE) -->
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <!-- À configurer selon la Datasource de votre serveur -->
            <!-- <property name="jakarta.persistence.jtaDataSource" value="java:jboss/datasources/ExampleDS" /> -->
        </properties>
    </persistence-unit>
</persistence>
